<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AQUASTROKE — Season Plan Navigator</title>
<style>
:root{--brand:#0057FF;--brand-l:#EEF3FF;--ocean:#0A1628;--bg:#F7F9FC;--border:#E4E9F0;--text:#0A1628;--text-2:#4A5568;--text-3:#94A3B8;--green:#059669;--green-l:#D1FAE5;--amber:#D97706;--amber-l:#FEF3C7;--red:#DC2626;--red-l:#FEE2E2;--radius:10px}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text)}
.header{background:var(--ocean);padding:14px 20px;display:flex;align-items:center;justify-content:space-between}
.logo{font-size:14px;font-weight:900;letter-spacing:2px;color:white}
.phase-bar{display:flex;gap:6px;padding:12px 16px;background:white;border-bottom:1px solid var(--border);overflow-x:auto}
.ph-btn{padding:6px 14px;border-radius:100px;font-size:11px;font-weight:700;border:1.5px solid var(--border);background:white;color:var(--text-2);cursor:pointer;white-space:nowrap;transition:all .2s}
.ph-btn.active{background:var(--brand);color:white;border-color:var(--brand)}
.week-nav{display:flex;align-items:center;gap:10px;padding:12px 16px;background:white;border-bottom:1px solid var(--border)}
.nav-btn{width:34px;height:34px;border-radius:50%;border:1.5px solid var(--border);background:white;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center}
.nav-btn:hover{border-color:var(--brand);color:var(--brand)}
.nav-info{flex:1}
.nav-title{font-size:16px;font-weight:800}
.nav-sub{font-size:12px;color:var(--text-3);margin-top:2px}
.dots-wrap{padding:8px 16px;background:white;border-bottom:1px solid var(--border);display:flex;gap:4px;flex-wrap:wrap}
.wdot{width:24px;height:24px;border-radius:50%;border:1.5px solid var(--border);background:white;cursor:pointer;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;color:var(--text-3);transition:all .15s}
.wdot:hover{border-color:var(--brand);color:var(--brand)}
.wdot.cur{background:var(--brand);color:white;border-color:var(--brand)}
.wdot.trial-dot{border-color:#D97706;color:#D97706}
.wdot.trial-dot.cur{background:#D97706;color:white}
.goal-box{padding:12px 16px;border-bottom:1px solid var(--border)}
.goal-label{font-size:10px;font-weight:700;color:var(--brand);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
.goal-text{font-size:13px;color:var(--text-2);line-height:1.5}
.trial-pill{display:inline-flex;align-items:center;gap:5px;background:#D97706;color:white;padding:2px 10px;border-radius:100px;font-size:10px;font-weight:700;margin-bottom:6px}
.sessions{padding:12px 16px;display:flex;flex-direction:column;gap:10px}
.week-total{background:var(--ocean);color:white;border-radius:var(--radius);padding:14px 18px;display:flex;justify-content:space-between;align-items:center}
.wt-lbl{font-size:11px;color:#475569}
.wt-val{font-size:20px;font-weight:900}
.scard{background:white;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.shdr{display:flex;align-items:center;gap:10px;padding:12px 14px;cursor:pointer;border-bottom:1px solid transparent}
.shdr:hover{background:var(--bg)}
.sday{width:42px;height:42px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;flex-shrink:0}
.d-sat{background:#EEF3FF;color:var(--brand)}
.d-sun{background:#FEE2E2;color:var(--red)}
.d-mon{background:#D1FAE5;color:var(--green)}
.d-tue{background:#FEF3C7;color:var(--amber)}
.d-wed{background:#E0F2FE;color:#0891B2}
.d-thu{background:#F3E8FF;color:#7C3AED}
.d-rest{background:var(--border);color:var(--text-3)}
.smain{flex:1}
.sfocus{font-size:13px;font-weight:700;margin-bottom:3px}
.stags{display:flex;gap:6px;flex-wrap:wrap}
.stag{font-size:10px;padding:2px 7px;border-radius:100px;font-weight:600}
.tvol{background:var(--brand-l);color:var(--brand)}
.tint{background:var(--amber-l);color:var(--amber)}
.ttool{background:var(--green-l);color:var(--green)}
.chev{font-size:11px;color:var(--text-3);transition:transform .2s}
.chev.open{transform:rotate(180deg)}
.sbody{display:none;padding:14px;border-top:1px solid var(--border)}
.sbody.open{display:block}
.srow{margin-bottom:12px}
.slbl{font-size:10px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
.sval{font-size:12px;color:var(--text-2);line-height:1.6;white-space:pre-wrap}
.nbox{background:#FFF7ED;border-left:3px solid var(--amber);border-radius:0 6px 6px 0;padding:8px 10px;font-size:11px;color:#92400E;line-height:1.5}
.rest-card{background:var(--border);border-radius:var(--radius);padding:16px;text-align:center;color:var(--text-3);font-weight:600;font-size:13px}
</style>
</head>
