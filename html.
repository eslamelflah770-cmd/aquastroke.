let curWeek = 1;

const DAY_CLASS = {
  'Sat':'d-sat','Sun':'d-rest','Mon':'d-mon','Tue':'d-tue',
  'Wed':'d-wed','Thu':'d-thu','Fri':'d-rest'
};

function getDayClass(day) {
  for(const [k,v] of Object.entries(DAY_CLASS)) {
    if(day.startsWith(k)) return v;
  }
  return 'd-mon';
}

function renderDots(phase) {
  const cont = document.getElementById('dotsWrap');
  cont.innerHTML = '';
  Object.values(PLAN).forEach(w => {
    if(w.phase !== phase) return;
    const d = document.createElement('div');
    d.className = 'wdot' + (w.isTrial?' trial-dot':'') + (w.week===curWeek?' cur':'');
    d.textContent = w.week;
    d.onclick = () => renderWeek(w.week);
    cont.appendChild(d);
  });
}

function renderWeek(n) {
  curWeek = n;
  const w = PLAN[String(n)];
  if(!w) return;

  document.getElementById('navTitle').textContent = `Week ${w.week} — ${w.phase}`;
  document.getElementById('navSub').textContent = w.goal.substring(0,60) + (w.goal.length>60?'...':'');

  const goalBox = document.getElementById('goalBox');
  goalBox.innerHTML = (w.isTrial ? '<div class="trial-pill">⭐ Official Trial Week</div>' : '') +
    '<div class="goal-label">Week ' + w.week + ' Goal</div>' +
    '<div class="goal-text">' + w.goal + '</div>';

  const cont = document.getElementById('sessionsContainer');
  cont.innerHTML = '';

  const totalVol = w.sessions.reduce((s,se) => s+(se.volume||0), 0);
  cont.innerHTML = `<div class="week-total">
    <div><div class="wt-lbl">Weekly Volume</div><div class="wt-val">${totalVol.toLocaleString()}m</div></div>
    <div style="text-align:right"><div class="wt-lbl">Sessions</div><div class="wt-val">${w.sessions.length}</div></div>
  </div>`;

  // Add Friday rest
  const days = ['Sat','Sun','Mon','Tue','Wed','Thu'];
  const sessionsByDay = {};
  w.sessions.forEach(se => {
    for(const d of days) { if(se.day.startsWith(d)) { sessionsByDay[d] = se; break; } }
  });

  days.forEach(day => {
    const se = sessionsByDay[day];
    if(!se) {
      if(day === 'Sun') {
        const r = document.createElement('div');
        r.className = 'rest-card';
        r.textContent = '🔴 SUNDAY — Full Rest Day';
        cont.appendChild(r);
      }
      return;
    }

    const card = document.createElement('div');
    card.className = 'scard';
    const dc = getDayClass(se.day);
    const tags = [
      se.volume ? `<span class="stag tvol">📏 ${se.volume.toLocaleString()}m</span>` : '',
      se.intensity ? `<span class="stag tint">⚡ ${se.intensity}</span>` : '',
      se.tools ? `<span class="stag ttool">🏊 ${se.tools.split(',')[0]}</span>` : ''
    ].filter(Boolean).join('');

    const rows = [
      se.warmup ? `<div class="srow"><div class="slbl">Warm-Up</div><div class="sval">${se.warmup}</div></div>` : '',
      se.mainSet ? `<div class="srow"><div class="slbl">Main Set</div><div class="sval">${se.mainSet}</div></div>` : '',
      se.skills ? `<div class="srow"><div class="slbl">Skills Set</div><div class="sval">${se.skills}</div></div>` : '',
      se.cooldown ? `<div class="srow"><div class="slbl">Cool Down</div><div class="sval">${se.cooldown}</div></div>` : '',
      (se.rest||se.tools) ? `<div style="display:flex;gap:16px;margin-bottom:10px">
        ${se.rest?`<div><div class="slbl">Rest</div><div class="sval">${se.rest}</div></div>`:''}
        ${se.tools?`<div><div class="slbl">Tools</div><div class="sval">${se.tools}</div></div>`:''}
      </div>` : '',
      se.notes ? `<div class="nbox">📋 ${se.notes}</div>` : ''
    ].filter(Boolean).join('');

    card.innerHTML = `
      <div class="shdr" onclick="toggle(this)">
        <div class="sday ${dc}">${day}</div>
        <div class="smain">
          <div class="sfocus">${se.focus}</div>
          <div class="stags">${tags}</div>
        </div>
        <div class="chev">▼</div>
      </div>
      <div class="sbody">${rows}</div>
    `;
    cont.appendChild(card);
  });

  // Friday rest
  const fri = document.createElement('div');
  fri.className = 'rest-card';
  fri.textContent = '🟢 FRIDAY — Full Rest Day';
  cont.appendChild(fri);

  renderDots(w.phase);
}

function toggle(hdr) {
  const body = hdr.nextElementSibling;
  const chev = hdr.querySelector('.chev');
  body.classList.toggle('open');
  chev.classList.toggle('open');
}

function prevWeek() { if(curWeek>1) renderWeek(curWeek-1); }
function nextWeek() { if(curWeek<36) renderWeek(curWeek+1); }

function filterPhase(btn, phase) {
  document.querySelectorAll('.ph-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  const first = Object.values(PLAN).find(w=>w.phase===phase);
  if(first) renderWeek(first.week);
}

renderWeek(1);
</script>

</body>
</html>